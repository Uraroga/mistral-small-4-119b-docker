# Esempio pubblico di configurazione.
# Copiare questo file in .env e adattare i valori alla propria rete locale.
# Non inserire password, token, chiavi o percorsi personali nel repository.

# Revisione e immagini llama.cpp.
# Le due immagini saranno costruite localmente dalla stessa revisione del sorgente
# con GGML_RPC=ON, usando un tag o commit preciso.
LLAMA_CPP_REF=b9858
LLAMA_SERVER_IMAGE=local/mistral-small-4-llama-server-rpc-avx2:dev
LLAMA_RPC_IMAGE=local/mistral-small-4-rpc-server-avx:dev

# Profili CPU di compilazione
# atlas5 e argo3 devono usare la stessa LLAMA_CPP_REF.
# Le due build devono continuare a usare la stessa LLAMA_CPP_REF.
# I profili CPU sono differenti e sono stati verificati sulle CPU indicate nel progetto.
# Ogni altro utente deve eseguire scripts/verifica-cpu.sh e adattare il proprio file .env.
# Non creare un'unica immagine AVX2 da usare su entrambi i nodi.
# Non usare una build AVX2 sul nodo configurato con RPC_CPU_PROFILE=avx.
# RPC_GGML_AVX2 deve rimanere obbligatoriamente OFF per l'i3-3240.
MAIN_CPU_PROFILE=avx2
RPC_CPU_PROFILE=avx

MAIN_GGML_NATIVE=OFF
MAIN_GGML_AVX=ON
MAIN_GGML_AVX2=ON
MAIN_GGML_FMA=ON
MAIN_GGML_F16C=ON
MAIN_GGML_BMI2=ON

RPC_GGML_NATIVE=OFF
RPC_GGML_AVX=ON
RPC_GGML_AVX2=OFF
RPC_GGML_FMA=OFF
RPC_GGML_F16C=ON
RPC_GGML_BMI2=OFF

# Nodo RPC
# RPC_HOST è l'indirizzo LAN del nodo remoto visto dal nodo principale.
# RPC_BIND_HOST è l'indirizzo interno sul quale il processo ascolta nel container.
# La porta RPC deve essere raggiungibile soltanto dalla rete locale fidata.
# Nella revisione b9858 ggml-rpc-server supporta l'opzione --threads.
RPC_HOST=192.168.1.20
RPC_BIND_HOST=0.0.0.0
RPC_PORT=50052
RPC_THREADS=4

# Server principale
# SERVER_BIND_HOST è usato dentro il container.
# SERVER_PUBLISH_HOST controlla su quale interfaccia dell'host viene pubblicata la porta.
# 127.0.0.1 limita inizialmente l'accesso al solo computer locale.
SERVER_BIND_HOST=0.0.0.0
SERVER_PUBLISH_HOST=127.0.0.1
SERVER_PORT=8080
MAIN_THREADS=4

# Modello
# Percorso del modello GGUF sull'host e nel container.
MODEL_HOST_DIR=/percorso/ai/modelli/Mistral-Small-4-119B-2603-UD-Q3_K_M
MODEL_CONTAINER_DIR=/models
MODEL_FILENAME=Mistral-Small-4-119B-2603-UD-Q3_K_M-00001-of-00003.gguf

# Parametri del modello
# Configurazione prudente preparata per il primo test con Mistral Small 4 119B.
# Il modello puo' essere composto da piu' frammenti GGUF: MODEL_FILENAME deve indicare
# il primo frammento, per esempio nome-00001-of-00003.gguf.
CONTEXT_SIZE=4096
DEFAULT_MAX_TOKENS=2048
# N_GPU_LAYERS=auto lascia a llama.cpp la scelta iniziale del numero di layer da assegnare al dispositivo RPC.
N_GPU_LAYERS=auto
# TENSOR_SPLIT vuoto lascia la distribuzione automatica.
TENSOR_SPLIT=
# SPLIT_MODE=layer usa la suddivisione per layer.
SPLIT_MODE=layer
FIT_MODE=on
# FIT_TARGET_MIB=2048 richiede prudenzialmente circa 2 GiB di margine sul dispositivo RPC.
FIT_TARGET_MIB=2048
FIT_CONTEXT=4096
# SERVER_PARALLEL=1 limita il primo test a un solo slot.
SERVER_PARALLEL=1
# SERVER_CACHE_RAM_MIB=0 disabilita inizialmente la cache RAM aggiuntiva del server.
SERVER_CACHE_RAM_MIB=0
# SERVER_CACHE_PROMPT=false disabilita il riuso della prompt cache nel primo test.
SERVER_CACHE_PROMPT=false
# SERVER_UI_ENABLED=false disabilita la Web UI incorporata.
SERVER_UI_ENABLED=false
SERVER_STARTUP_TIMEOUT_SECONDS=3600
SERVER_HEALTH_INTERVAL_SECONDS=5

# Cache RPC
# La cache evita di trasferire nuovamente grandi tensori a ogni avvio.
# Il percorso host deve rimanere fuori dal repository.
# RPC_CACHE_CONTAINER_DIR e' la directory base montata nel container.
# ggml-rpc-server usa al suo interno la sottodirectory rpc.
# Il percorso finale nel container sara' /var/cache/llama.cpp/rpc.
RPC_CACHE_ENABLED=true
RPC_CACHE_HOST_DIR=/percorso/cache/llama-rpc
RPC_CACHE_CONTAINER_DIR=/var/cache/llama.cpp

# Argomenti aggiuntivi
# Lasciare vuoto se non necessari.
LLAMA_SERVER_EXTRA_ARGS=--jinja
LLAMA_RPC_EXTRA_ARGS=
